# -----------------------------------------------------------------------------
# English
# For local execution (npm run trade:local). Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# 
# 日本語
# ローカル実行 (npm run trade:local) 用。このファイルを .env にコピーして値を入れてください。
# .env は絶対に git にコミットしないでください。
# -----------------------------------------------------------------------------

COINCHECK_API_KEY=
COINCHECK_API_SECRET=
# メインのAPIキー
GEMINI_API_KEY=
# 予備のAPIキー
GEMINI_API_KEY_FALLBACK=

# -----------------------------------------------------------------------------
# Safety Settings / 安全設定
# If omitted, safe default values will be used. / 省略時は安全側のデフォルトが使われます。
# -----------------------------------------------------------------------------
DRY_RUN=true
ORDER_PCT_OF_ASSETS=15
MAX_ORDER_JPY_CAP=50000
MAX_ORDERS_PER_CYCLE=3
MAX_COIN_SHARE_PCT=25
JPY_RESERVE_PCT=10
MIN_CONFIDENCE=0.7
MIN_LIQUIDITY_JPY=100000
STOP_LOSS_PCT=10
MAX_DRAWDOWN_24H_PCT=10
EXCLUDE_PAIRS=
GOAL_ASSETS_JPY=1300000000
# 複数モデルを指定するとエラー時にフォールバックします (カンマ区切り)
GEMINI_MODEL=gemini-3.1-flash-lite,gemini-3.5-flash,gemini-3.0-flash,gemini-2.5-flash,gemini-2.5-flash-lite
# フォールバックの優先順位: 'KEY_FIRST' (APIキーを先に切り替え) または 'MODEL_FIRST' (モデルを先に切り替え)
FALLBACK_STRATEGY=MODEL_FIRST

# Allowed emails for Cognito login / ログインを許可するGmailアドレス
ALLOWED_EMAILS=